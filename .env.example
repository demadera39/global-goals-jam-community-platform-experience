# =============================================================================
# Global Goals Jam Community Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required — used by the frontend Vite app)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ---------------------------------------------------------------------------
# Stripe (required for payments — publishable key used by frontend)
# ---------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ---------------------------------------------------------------------------
# Edge Function secrets — set via `supabase secrets set KEY=VALUE`
# These are NOT used by the frontend; they run server-side.
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
# GOOGLE_SEARCH_API_KEY=AIza...
# GOOGLE_SEARCH_CX=abc123...
# GEMINI_API_KEY=AIza...
