# =============================================================================
# Global Goals Jam Community Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required — used by the frontend Vite app)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ---------------------------------------------------------------------------
# Stripe (required for payments — publishable key used by frontend)
# ---------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ---------------------------------------------------------------------------
# Metodic method library (optional — the toolkit generator grounds agendas in
# Metodic's public, read-only method database. Sensible defaults are baked into
# src/lib/metodicMethods.ts, so set these only to override the cross-project source.)
# ---------------------------------------------------------------------------
# VITE_METODIC_SUPABASE_URL=https://sjqautbrynptqfeziocu.supabase.co
# VITE_METODIC_ANON_KEY=eyJ...public-read-only-anon-key

# ---------------------------------------------------------------------------
# Edge Function secrets — set via `supabase secrets set KEY=VALUE`
# These are NOT used by the frontend; they run server-side.
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
# GOOGLE_SEARCH_API_KEY=AIza...
# GOOGLE_SEARCH_CX=abc123...
# ANTHROPIC_API_KEY=sk-ant-...   # powers the AI toolkit generator (gemini-ai fn, Claude)
